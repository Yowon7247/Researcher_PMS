<Window x:Class="PMS_Client.PMS_UI.PMS_Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PMS_Client.PMS_UI"
        mc:Ignorable="d"
        Title="PMS_Login" Height="800" Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Label Content="ID" HorizontalAlignment="Left" Height="40" Margin="115,364,0,0" VerticalAlignment="Top" Width="50" FontSize="20"/>
        <Label Content="PW" HorizontalAlignment="Left" Height="40" Margin="115,424,0,0" VerticalAlignment="Top" Width="50" FontSize="20"/>
        <Border 
            HorizontalAlignment="Left"
            Margin="165,364,0,0"
            VerticalAlignment="Top"
            Width="224"
            Height="40"
            BorderBrush="Black"
            BorderThickness="0,0,0,1">
            <TextBox 
                x:Name="tbID"
                Text=""
                BorderThickness="0"
                Background="Transparent"
                FontSize="16"
                Foreground="#B2000000"
                VerticalContentAlignment="Center"/>
        </Border>

        <Border 
            HorizontalAlignment="Left"
            Margin="165,424,0,0"
            VerticalAlignment="Top"
            Width="224"
            Height="40"
            BorderBrush="Black"
            BorderThickness="0,0,0,1">
            <PasswordBox 
                x:Name="tbPW"
                BorderThickness="0"
                Background="Transparent"
                FontSize="16"
                VerticalContentAlignment="Center"/>
        </Border>
        <!-- 로그인 버튼 -->
        <Button 
            x:Name="btnLogin"
            Content="로그인"
            Width="130"
            Height="45"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="115,500,0,0"
            Background="#015AAA"
            Foreground="White"
            BorderBrush="#015AAA"
            BorderThickness="1"
            FontSize="18"
            FontWeight="SemiBold"
            Cursor="Hand" Click="btnLogin_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#016CCB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#014B8E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <!-- 회원가입 버튼 -->
        <Button 
            x:Name="btnJoin"
            Content="회원가입"
            Width="130"
            Height="45"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="255,500,0,0"
            Background="White"
            Foreground="#015AAA"
            BorderBrush="#015AAA"
            BorderThickness="2"
            FontSize="18"
            FontWeight="SemiBold"
            Cursor="Hand" Click="btnJoin_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                        Property="Background"
                                        Value="#EEF6FF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                        Property="Background"
                                        Value="#D9ECFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
        <CheckBox 
            x:Name="chkRememberID"
            Content="아이디 기억하기"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="115,475,0,0"
            FontSize="14"
            Cursor="Hand"/>

        <Button 
            x:Name="btnAdminContact"
            Width="110"
            Height="30"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,472,115,0"
            Background="Transparent"
            BorderThickness="0"
            Cursor="Hand"
            Click="btnAdminContact_Click">

            <TextBlock Text="관리자 문의"
                Foreground="#015AAA"
                TextDecorations="Underline"
                FontSize="14"/>
        </Button>
        <Image HorizontalAlignment="Left" Height="196" Margin="115,130,0,0" VerticalAlignment="Top" Width="274" Source="/Resources/KRRI_Logo.jpg"/>
    </Grid>
</Window>
